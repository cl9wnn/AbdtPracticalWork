{
  "App": {
    "DbConnectionString": "Host=library-service-db;Port=5432;Database=library;Username=postgres;Password=admin",

    "Redis": {
      "RedisCacheConnection": "redis:6379",
      "RedisCachePrefix": "app:"
    },

    "Minio": {
      "Endpoint": "minio:9000",
      "AccessKey": "admin",
      "SecretKey": "admin123",
      "BucketName": "bookcovers",
      "UseSsl": false,
      "ExpirySeconds": 3600
    },

    "Kafka": {
      "BootstrapServers": "kafka:29092",
      "Topic": "library-events"
    },
    
    "BooksCache": {
      "BooksCacheVersionPrefix": "books:cache:version",
      "BooksListCache": {
        "KeyPrefix": "books:list",
        "TtlMinutes": 10
      },
      "BookDetailsCache": {
        "KeyPrefix": "book:details",
        "TtlMinutes": 30
      },
      "LibraryBooksCache": {
        "KeyPrefix": "library:books",
        "TtlMinutes": 5
      }
    },

    "ReadersCache": {
      "ReadersCacheVersionPrefix": "readers:cache:version",
      "ReadersBooksCache": {
        "KeyPrefix": "reader:books",
        "TtlMinutes": 15
      }
    },

    "EmailSettings": {
      "SmtpServer": "smtp4dev",
      "SmtpPort": 25,
      "UseSsl": false,
      "UserName": "library-admin",
      "Password": "admin",
      "SenderName": "Библиотека",
      "SenderEmail": "noreply@library.local",
      "AdminEmails": [
        "admin@library.local"
      ]
    },

    "EmailTemplateSettings": {
      "ReturnReminder": {
        "SubjectTemplate": "Напоминание о возврате книги: \"{0}\"",
        "DaysBeforeDueDate": 3,
        "LibraryName": "Центральная городская библиотека",
        "LibraryAddress": "г. Казань, ул. Пушкина, 10",
        "LibraryPhone": "+7 (495) 123-45-67",
        "WorkingHours": "Пн–Пт 09:00–20:00, Сб 10:00–18:00"
      },
      "WeeklyReport": {
        "SubjectTemplate": "Еженедельный отчет библиотеки за период {0} - {1}",
        "AdminEmails": [
          "admin@library.local",
          "director@library.local"
        ],
        "ReportRetentionDays": 90
      }
    },

    "JobSettings": {
      "Jobs": {
        "ArchiveJob": {
          "CronExpression": "0 * * * * ?",
          "MaxRetries": 3,
          "TimeoutMinutes": 30
        },
        "ReturnReminderJob": {
          "CronExpression": "0 * * * * ?",
          "MaxRetries": 5,
          "TimeoutMinutes": 15
        },
        "WeeklyReportJob": {
          "CronExpression": "0 * * * * ?",
          "MaxRetries": 2,
          "TimeoutMinutes": 60
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
