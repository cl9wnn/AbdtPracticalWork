{
  "App": {
    "DbConnectionString": "Host=localhost;Port=5434;Database=reports;Username=postgres;Password=admin",

    "Redis": {
      "RedisCacheConnection": "localhost:6379",
      "RedisCachePrefix": "app:"
    },

    "Minio": {
      "Endpoint": "localhost:9000",
      "AccessKey": "admin",
      "SecretKey": "admin123",
      "BucketName": "reports",
      "UseSsl": false,
      "ExpirySeconds": 3600
    },

    "Kafka": {
      "BootstrapServers": "localhost:29092",
      "Topic": "library-events",
      "GroupId": "reports-service",
      "AutoOffsetReset": "earliest",
      "EnableAutoCommit": false
    },

    "BooksCache": {
      "ReportsCacheVersionPrefix": "reports:cache:version",
      "ReportsListCache": {
        "KeyPrefix": "reports:list",
        "TtlMinutes": 1440
      }
    },

    "EmailSettings": {
      "SmtpServer": "localhost",
      "SmtpPort": 2525,
      "UseSsl": false,
      "UserName": "library-admin",
      "Password": "admin",
      "SenderName": "Библиотека",
      "SenderEmail": "noreply@library.local",
      "AdminEmails": [
        "admin@library.local"
      ]
    },

    "EmailTemplateSettings": {
      "WeeklyReport": {
        "SubjectTemplate": "Еженедельный отчет библиотеки за период {0} - {1}",
        "AdminEmails": [
          "admin@library.local",
          "director@library.local"
        ],
        "ReportRetentionDays": 90
      }
    },

    "JobSettings": {
      "Jobs": {
        "WeeklyReportJob": {
          "CronExpression": "0 * * * * ?",
          "MaxRetries": 2,
          "TimeoutMinutes": 60
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
